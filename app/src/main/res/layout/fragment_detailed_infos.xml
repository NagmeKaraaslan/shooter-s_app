<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF4EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Detailed Infos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detailed Infos"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvAjans"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agency:   —"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvBasedIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Based In:   —"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvYas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Age:   —"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="20dp"/>

        <!-- Ayırıcı -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D9D9D9"
            android:layout_marginBottom="16dp"/>

        <!-- Vücut Ölçüleri -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vücut Ölçüleri"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvBoy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Boy:   — cm"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvKilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kilo:   — kg"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvBel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bel:   — cm"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvGogus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Göğüs:   — cm"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvKalca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kalça:   — cm"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvBacakBoyu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bacak Boyu:   — cm"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="20dp"/>

        <!-- Ayırıcı -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D9D9D9"
            android:layout_marginBottom="16dp"/>

        <!-- Biography -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biography"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvBiyografi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="13sp"
            android:fontFamily="@font/playfair_display"
            android:textColor="#1C1C1C"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>
</ScrollView>