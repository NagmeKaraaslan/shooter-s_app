<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#AF9B8F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivShootImage"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#8D7A71" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvModelLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model Name"
                android:textColor="#3D2B1F"
                android:textSize="14sp"
                android:fontFamily="@font/playfair_display"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPhotographerLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvModelLink"
                android:layout_marginTop="4dp"
                android:text="Photographer Name"
                android:textColor="#3D2B1F"
                android:textSize="12sp"
                android:fontFamily="@font/playfair_display" />

            <TextView
                android:id="@+id/tvBrandName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvPhotographerLink"
                android:layout_marginTop="8dp"
                android:text="Brand / Company"
                android:textColor="#3D2B1F"
                android:textSize="12sp"
                android:fontFamily="@font/playfair_display" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:text="20.05.2024"
                android:textColor="#3D2B1F"
                android:textSize="10sp"
                android:fontFamily="@font/playfair_display" />

        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>