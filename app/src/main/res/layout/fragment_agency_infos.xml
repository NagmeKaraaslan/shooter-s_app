<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF4EA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvAgencyCeoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agency CEO:   "
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/playfair_display"
                android:textColor="#1C1C1C"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvAgencyCeo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:fontFamily="@font/playfair_display"
                android:textColor="#715050"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvBasedInLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Based In:   "
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/playfair_display"
                android:textColor="#1C1C1C"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvBasedIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:fontFamily="@font/playfair_display"
                android:textColor="#715050"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvAgeRangeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age range:   "
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/playfair_display"
                android:textColor="#1C1C1C"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvAgeRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:fontFamily="@font/playfair_display"
                android:textColor="#715050"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_power"
        app:tint="@android:color/white"
        android:backgroundTint="#715050"
        android:contentDescription="Logout"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>